# Arena64 environment
# Local: copy to .env. Production: see docs/deploy.md (Railway + Vercel).
APP_ENV=development
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
# Host port 15432 — docker-compose maps container 5432 → host 15432 (avoids system Postgres on 5432)
# Railway: set DATABASE_URL from Postgres plugin (postgres:// is auto-normalized to +asyncpg)
DATABASE_URL=postgresql+asyncpg://arena64:arena64@localhost:15432/arena64
DATABASE_URL_SYNC=postgresql://arena64:arena64@localhost:15432/arena64

# Redis
# Railway: set REDIS_URL from Redis plugin
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
# Production: https://your-app.vercel.app (comma-separated for preview + prod)
API_CORS_ORIGINS=http://localhost:3000
SERVICE_API_KEY=arena64-dev-service-key

# AI Runtime (apps/ai-runtime) — deploy as separate Railway service
# ARENA64_API_URL=https://your-api.up.railway.app
# RUNTIME_POLL_SECONDS=2.5
# RUNTIME_LLM_ENABLED=true
# Prefer local Postgres (15432) for live demos — remote DB slows the bracket.

# Frontend (local). Vercel: use apps/web/.env.example → Project env vars
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_CHAIN_ID=1439
NEXT_PUBLIC_CHAIN_NAME=Injective EVM Testnet
NEXT_PUBLIC_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
# Optional — enables WalletConnect QR (get ID at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Injective — DEFAULT TESTNET. Do not set mainnet until checklist passes.
# Profiles auto-fill chain/USDC/Iris/x402 CAIP-2 when left unset.
INJECTIVE_NETWORK=testnet
# Optional overrides (leave blank to use profile defaults):
# INJECTIVE_EVM_CHAIN_ID=1439
# INJECTIVE_USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
# X402_NETWORK=eip155:1439
# CCTP_IRIS_API=https://iris-api-sandbox.circle.com
# CCTP_DOMAIN=29
X402_FACILITATOR_URL=https://x402.org/facilitator
CCTP_REQUIRE_ATTESTATION=true
X402_REQUIRE_VERIFY=true
# If public facilitator lacks eip155:1439, allow recorded proof on testnet only:
X402_ALLOW_TESTNET_FALLBACK=true
# Mainnet (ONLY after testnet checklist):
# INJECTIVE_NETWORK=mainnet
# INJECTIVE_USDC_ADDRESS=0xa00C59fF5a080D2b954d0c75e46E22a0c371235a
# X402_NETWORK=eip155:1776
# CCTP_IRIS_API=https://iris-api.circle.com
# DEMO_FAUCET_ENABLED=false

# Web Scout — free DuckDuckGo HTML search → football news/data platforms
SCOUT_ALLOWED_HOSTS=espn.com,www.espn.com,bbc.com,www.bbc.com,goal.com,www.goal.com,fifa.com,www.fifa.com,skysports.com,www.skysports.com,transfermarkt.com,www.transfermarkt.com,reuters.com,www.reuters.com,theguardian.com,www.theguardian.com,uefa.com,www.uefa.com,flashscore.com,www.flashscore.com,sofascore.com,www.sofascore.com,whoscored.com,www.whoscored.com,cbssports.com,www.cbssports.com,marca.com,www.marca.com,mlssoccer.com,www.mlssoccer.com
SCOUT_AUTO_APPROVE=true

# LLM stack (Voya pattern): Ollama → Qwen → heuristics
# AI_PROVIDER: ollama | auto | qwen | rules
AI_PROVIDER=auto
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
OLLAMA_TIMEOUT_SECONDS=120
# Cloud Qwen / DashScope (optional — leave empty to stay local-only)
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MODEL_STUDIO_WORKSPACE_ID=
MODEL_STUDIO_REGION=ap-southeast-1
QWEN_CHAT_MODEL=qwen-plus

# Admin
ADMIN_WALLETS=

# Product funding — real Injective testnet USDC deposits (faucet off by default)
DEMO_FAUCET_ENABLED=false
DEMO_FAUCET_AMOUNT_USDC=50
# Address that receives USDC transfers; API verifies Transfer logs then credits ledger
ARENA64_TREASURY_ADDRESS=
# Hot-wallet key for the same address above — required for withdrawals (USDC transfer out)
# ARENA64_TREASURY_PRIVATE_KEY=

# Testnet INJ faucet (InjFaucet.sol) — 1 INJ once per wallet; API calls claimFor
# Deploy: cd blockchain && ./script/deploy_and_fund.sh 20
INJ_KEY_EVM=
INJ_FAUCET_ADDRESS=

# Continuous Web Scout (bootstrap world_cup_history.json, then interval scrapes)
SCOUT_SCHEDULER_ENABLED=true
SCOUT_INTERVAL_MINUTES=360
SCOUT_BOOTSTRAP_ON_START=true
SCOUT_AUTO_APPROVE=true
