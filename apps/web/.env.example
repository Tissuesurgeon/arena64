# Vercel Project → Settings → Environment Variables
# Dashboard: Root Directory = apps/web (not monorepo root)

# Browser uses same-origin /arena-api proxy (next.config.js → Railway).
# Set this so the rewrite target is correct (no trailing slash):
NEXT_PUBLIC_API_URL=https://arena64-production.up.railway.app
# Or server-only override:
# ARENA64_API_ORIGIN=https://arena64-production.up.railway.app

# WebSocket — must be absolute wss (proxy is HTTP-only)
NEXT_PUBLIC_WS_URL=wss://arena64-production.up.railway.app/ws

NEXT_PUBLIC_CHAIN_ID=1439
NEXT_PUBLIC_CHAIN_NAME=Injective EVM Testnet
NEXT_PUBLIC_RPC_URL=https://k8s.testnet.json-rpc.injective.network/

# Optional — WalletConnect Cloud project id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Alias used by wagmi helper
NEXT_PUBLIC_WC_PROJECT_ID=
