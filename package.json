{
  "name": "arena64",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=arena64-web",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "build": "npm run build --workspace=arena64-web",
    "build:vercel": "ARENA64_BUILD_FROM_ROOT=1 next build apps/web"
  },
  "dependencies": {
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
